# Database
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# Application
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173

# Panel domain (used by Traefik for routing + SSL cert)
PANEL_DOMAIN=server.example.com

# Let's Encrypt — email for certificate registration and expiry notices
ACME_EMAIL=admin@example.com

# Traefik dashboard basic auth (generate with: htpasswd -nb user password)
# Leave empty to disable the dashboard route entirely
TRAEFIK_DASHBOARD_USERS=admin:$$apr1$$...
